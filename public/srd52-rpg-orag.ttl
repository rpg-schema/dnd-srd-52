srd52:BarbarianLevel5 a rpg:ClassLevelDefinition ; schema:name "Barbarian Level 5"@en ; rpg:levelDefinedInRuleSet srd52:SRD52 ; rpg:levelForClass srd52:Barbarian ; rpg:levelNumber 5 ; srd52:grantsFeature srd52:ExtraAttack .
srd52:WizardLevel1 a rpg:ClassLevelDefinition ; schema:name "Wizard Level 1"@en ; rpg:levelDefinedInRuleSet srd52:SRD52 ; rpg:levelForClass srd52:Wizard ; rpg:levelNumber 1 ; srd52:grantsFeature srd52:SpellcastingFeature, srd52:ArcaneRecovery .

